{
  "name": "openclaw-channel-clawwork",
  "version": "0.2.0",
  "type": "module",
  "description": "OpenClaw channel plugin for ClawWork desktop client",
  "main": "./src/index.ts",
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clawwork/shared": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
